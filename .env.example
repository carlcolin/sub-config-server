PORT=3210
HOST=127.0.0.1
ACCESS_TOKEN=***
# 多 token 可用英文逗号分隔，配置后会覆盖单个 ACCESS_TOKEN
# ACCESS_TOKENS=token1,token2
CONFIG_DIR=./configs
ROUTES_FILE=./routes.json
TRUST_PROXY=false
# 可选：用于启动日志和 /profiles 返回更实用的公网/域名地址
# PUBLIC_BASE_URL=https://sub.example.com
# Docker 直接映射端口到宿主机时，通常改成 0.0.0.0
# HOST=0.0.0.0
